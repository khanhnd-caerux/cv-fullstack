# .npmrc — CI registry configuration for @caeruxlab scope
# Uses GitLab CI Job Token injected automatically by the GitLab runner.
# Do NOT put real tokens here. Configure ~/.npmrc locally with your GitLab PAT.
@caeruxlab:registry=https://git.caerux.com/api/v4/projects/${CI_PROJECT_ID}/packages/npm/
//git.caerux.com/api/v4/projects/${CI_PROJECT_ID}/packages/npm/:_authToken=${CI_JOB_TOKEN}
